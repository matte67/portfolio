# Public TinaCloud project identifier embedded in the admin bundle.
TINA_PUBLIC_CLIENT_ID=

# Read-only build token. Configure it as a secret in Netlify; never expose it to Vite.
TINA_TOKEN=

# Optional explicit content branch. Netlify also exposes HEAD automatically.
TINA_PUBLIC_BRANCH=main

# Enable draft and archived content only on protected deploy previews.
VITE_CONTENT_PREVIEW=false
