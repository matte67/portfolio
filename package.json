{
  "name": "matteo-vittori-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:cms": "tinacms dev --noTelemetry -c \"vite --host 127.0.0.1\"",
    "validate:content": "node scripts/validate-content.mjs",
    "cms:audit": "tinacms audit --noTelemetry",
    "cms:build": "tinacms build --noTelemetry",
    "cms:build-if-configured": "node scripts/build-cms.mjs",
    "build": "npm run validate:content && npm run cms:build-if-configured && tsc -b && vite build",
    "postbuild": "node scripts/generate-route-metadata.mjs",
    "preview": "node scripts/preview-server.mjs",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run test:unit && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@mdx-js/react": "^3.1.1",
    "gsap": "^3.15.0",
    "mathjs": "^15.2.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tinacms": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tinacms/cli": "^2.5.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "gray-matter": "^4.0.3",
    "playwright": "^1.61.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
  }
}
